{
  "name": "pi-whatsapp-setup",
  "version": "0.1.0",
  "private": false,
  "description": "WhatsApp setup for Pi Agent: a local WhatsApp Web/Baileys bridge for running Pi from WhatsApp.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-agent",
    "whatsapp",
    "whatsapp-web",
    "baileys",
    "ai-agent",
    "local-ai",
    "self-hosted",
    "chatbot",
    "automation",
    "agent-gateway",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aifunmobi/pi_whatsapp_setup.git"
  },
  "bugs": {
    "url": "https://github.com/aifunmobi/pi_whatsapp_setup/issues"
  },
  "homepage": "https://github.com/aifunmobi/pi_whatsapp_setup#readme",
  "files": [
    ".env.example",
    "docs/",
    "launchd/",
    "skills/",
    "src/",
    "systemd/",
    "test/",
    "LICENSE",
    "README.md"
  ],
  "pi": {
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "pair": "node src/pair.mjs",
    "start": "node src/gateway.mjs",
    "check": "node --check src/lib.mjs && node --check src/gateway.mjs && node --check src/pair.mjs && node --check test/lib.test.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
