<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.pi-whatsapp</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/PATH/TO/pi_whatsapp_setup/src/gateway.mjs</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/PATH/TO/pi_whatsapp_setup</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/YOU</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/PATH/TO/pi_whatsapp_setup/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/PATH/TO/pi_whatsapp_setup/logs/launchd.err.log</string>
</dict>
</plist>

