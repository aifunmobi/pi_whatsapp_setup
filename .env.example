# Copy to .env and edit.

# Required. Comma-separated WhatsApp sender IDs allowed to trigger Pi.
# Use country code, no plus, spaces, or dashes.
# Example: WHATSAPP_ALLOWED_SENDERS=15551234567
WHATSAPP_ALLOWED_SENDERS=

# self-chat = you link your own WhatsApp account and message yourself.
# bot = you link a separate assistant WhatsApp account and message it from
# an allowed owner number.
WHATSAPP_MODE=self-chat

# Optional prefix used in self-chat mode so the bridge can ignore its own
# echoed replies after restarts.
SELF_CHAT_REPLY_PREFIX=Pi Agent

# Where Baileys stores WhatsApp Web credentials.
SESSION_DIR=./session

# Local health endpoint.
HEALTH_HOST=127.0.0.1
HEALTH_PORT=3091

# Pi CLI settings.
PI_BIN=pi
PI_WORKDIR=.
PI_MODEL=ollama/qwen3.6-35b-a3b-q8:latest
PI_THINKING=high
PI_TIMEOUT_MS=900000

# Optional. Append a local safety/policy prompt file when invoking Pi.
# PI_APPEND_SYSTEM_PROMPT=/path/to/APPEND_SYSTEM.md

